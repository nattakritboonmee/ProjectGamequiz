<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>แก้ไขชื่อเล่น - Quiz Game</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;600&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="/css/edit.css">
      <link rel="icon" type="image/png" href="image/logoproject.png">
</head>
<body>

    <div class="container">
        <div class="card">
            <h3>✏️ แก้ไขชื่อเล่น</h3>
            
            <div class="score-info">
                คะแนนเดิมของคุณ: <strong><%= score %> pts</strong>
            </div>
            
            <form action="/edit-nickname" method="POST">
                <input type="hidden" name="scoreId" value="<%= scoreId %>">
                
                <div class="form-group">
                    <label class="form-label">ชื่อเล่นใหม่:</label>
                    <input type="text" 
                           name="newNickname" 
                           class="form-control" 
                           value="<%= oldNickname %>" 
                           placeholder="ระบุชื่อเล่นใหม่..."
                           required 
                           minlength="2">
                </div>

                <div class="btn-group">
                    <button type="submit" class="btn btn-primary">บันทึกการแก้ไข</button>
                    <a href="/leaderboard" class="btn btn-light">ยกเลิก</a>
                </div>
            </form>
        </div>
    </div>

</body>
</html>